    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Enhanced HTML text extraction with title extraction\nconst item = $input.item.json;\n\ntry {\n  // Get the HTML content from HTTP Request\n  let htmlContent = item.data || '';\n  \n  if (!htmlContent) {\n    return {\n      json: {\n        ...item,\n        cleanedText: '',\n        error: 'No HTML content received'\n      }\n    };\n  }\n  \n  // STEP 1: Extract title from HTML\n  let pageTitle = '';\n  const titleMatch = htmlContent.match(/<title[^>]*>(.*?)<\\/title>/i);\n  if (titleMatch) {\n    pageTitle = titleMatch[1]\n      .replace(/&#8211;/g, '–')  // Replace HTML entity\n      .replace(/&amp;/g, '&')\n      .replace(/&lt;/g, '<')\n      .replace(/&gt;/g, '>')\n      .replace(/&quot;/g, '\"')\n      .replace(/&#39;/g, \"'\")\n      .trim();\n  }\n  \n  // STEP 2: Remove heavy content first to reduce size\n  let optimizedContent = htmlContent\n    .replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '') // Remove all scripts\n    .replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, '')   // Remove all styles\n    .replace(/<svg[^>]*>[\\s\\S]*?<\\/svg>/gi, '')       // Remove SVG graphics\n    .replace(/<img[^>]*>/gi, '')                       // Remove images\n    .replace(/data:image\\/[^;]*;base64,[^\"']*/gi, '')  // Remove base64 images\n    .replace(/<!--[\\s\\S]*?-->/g, '')                   // Remove comments\n    .replace(/<link[^>]*>/gi, '')                      // Remove link tags\n    .replace(/<meta[^>]*>/gi, '');                     // Remove meta tags\n  \n  // STEP 3: Focus on content-rich sections\n  const contentPatterns = [\n    /<main[^>]*>([\\s\\S]*?)<\\/main>/gi,\n    /<article[^>]*>([\\s\\S]*?)<\\/article>/gi,\n    /<div[^>]*class[^>]*(?:content|main|about|hero|intro)[^>]*>([\\s\\S]*?)<\\/div>/gi,\n    /<section[^>]*>([\\s\\S]*?)<\\/section>/gi,\n    /<header[^>]*>([\\s\\S]*?)<\\/header>/gi,\n    /<body[^>]*>([\\s\\S]*?)<\\/body>/gi\n  ];\n  \n  let mainContent = '';\n  for (const pattern of contentPatterns) {\n    const matches = optimizedContent.match(pattern);\n    if (matches && matches.length > 0) {\n      mainContent = matches[0];\n      break;\n    }\n  }\n  \n  // If no main content found, use the entire optimized content but limit it\n  if (!mainContent) {\n    mainContent = optimizedContent.substring(0, 15000); // Limit to 15KB\n  }\n  \n  // STEP 4: Extract navigation and key content\n  const navMatches = mainContent.match(/<nav[^>]*>([\\s\\S]*?)<\\/nav>/gi);\n  const headerMatches = mainContent.match(/<header[^>]*>([\\s\\S]*?)<\\/header>/gi);\n  const h1Matches = mainContent.match(/<h1[^>]*>([\\s\\S]*?)<\\/h1>/gi);\n  const h2Matches = mainContent.match(/<h2[^>]*>([\\s\\S]*?)<\\/h2>/gi);\n  \n  let combinedContent = mainContent;\n  if (navMatches) combinedContent = navMatches.join(' ') + ' ' + combinedContent;\n  if (headerMatches) combinedContent = headerMatches.join(' ') + ' ' + combinedContent;\n  if (h1Matches) combinedContent = h1Matches.join(' ') + ' ' + combinedContent;\n  if (h2Matches) combinedContent = h2Matches.join(' ') + ' ' + combinedContent;\n  \n  // STEP 5: Extract text and clean it\n  let textContent = combinedContent\n    .replace(/<[^>]*>/g, ' ')                          // Remove HTML tags\n    .replace(/&nbsp;/g, ' ')                           // Replace &nbsp; with space\n    .replace(/&amp;/g, '&')                            // Replace &amp; with &\n    .replace(/&lt;/g, '<')                             // Replace &lt; with \n    .replace(/&gt;/g, '>')                             // Replace &gt; with >\n    .replace(/&quot;/g, '\"')                           // Replace &quot; with \"\n    .replace(/&#39;/g, \"'\")                            // Replace &#39; with '\n    .replace(/&#8211;/g, '–')                          // Replace &#8211; with –\n    .replace(/\\s+/g, ' ')                              // Replace multiple spaces with single space\n    .replace(/\\n+/g, ' ')                              // Replace newlines with spaces\n    .trim();\n  \n  // STEP 6: Extract meaningful content (first 1500 characters)\n  const businessText = textContent.substring(0, 500);\n  \n  // STEP 7: Try to extract specific business-related sentences\n  const sentences = businessText.split(/[.!?]+/).filter(s => s.trim().length > 15);\n  const relevantSentences = sentences.filter(sentence => {\n    const lowerSentence = sentence.toLowerCase();\n    return lowerSentence.includes('company') || \n           lowerSentence.includes('business') || \n           lowerSentence.includes('service') || \n           lowerSentence.includes('solution') || \n           lowerSentence.includes('product') || \n           lowerSentence.includes('we') || \n           lowerSentence.includes('our') ||\n           lowerSentence.includes('provide') ||\n           lowerSentence.includes('offer') ||\n           lowerSentence.includes('specialize') ||\n           lowerSentence.includes('help') ||\n           lowerSentence.includes('develop') ||\n           lowerSentence.includes('create') ||\n           lowerSentence.includes('technology') ||\n           lowerSentence.includes('software') ||\n           lowerSentence.includes('digital');\n  });\n  \n  // Use relevant sentences or fallback to first part of text\n  const finalText = relevantSentences.length > 0 \n    ? relevantSentences.slice(0, 8).join('. ') + '.'\n    : businessText;\n  \n  return {\n    json: {\n      // Keep essential fields\n    \n      \"Company Name\": pageTitle,\n      \"cleanedText\": finalText,\n      \"textLength\": finalText.length,\n      \"scrapingStatus\": \"success\"\n    }\n  };\n  \n} catch (error) {\n  return {\n    json: {\n      \n      \"Company Name\": '',\n      \"cleanedText\": '',\n      \"error\": `HTML parsing failed: ${error.message}`,\n      \"scrapingStatus\": \"failed\"\n    }\n  };\n}"
      },
