    {
      "parameters": {
        "jsCode": "function extractDomain(itemData) {\n  // Handle the typo in your data structure\n  const companyName = itemData['Compnay Name'] || itemData['Company Name'] || '';\n  const domainProvided = itemData['Domain']?.trim();\n  const email = itemData['Email ']?.trim(); // Note: space after 'Email '\n  const website = itemData['Website']?.trim();\n  \n  let extractedDomain = '';\n  \n  // Priority 1: Use existing domain\n  if (domainProvided) {\n    extractedDomain = domainProvided;\n  }\n  // Priority 2: Extract from email\n  else if (email && email.includes('@')) {\n    extractedDomain = email.split('@')[1];\n  }\n  // Priority 3: Extract from website URL\n  else if (website && website.startsWith('http')) {\n    try {\n      const url = new URL(website);\n      extractedDomain = url.hostname.replace(/^www\\./, '');\n    } catch (e) {\n      extractedDomain = '';\n    }\n  }\n  \n  // Check if ALL three fields are missing\n  const isMissingAll = !domainProvided && !email && !website;\n  \n  if (isMissingAll) {\n    return {\n      ...itemData,\n      'Company Name': companyName, // Fix the typo\n      'Domain': '',\n      'Status': 'error',\n      'Error Log': 'Missing domain/email/website',\n      'Processed Date': new Date().toISOString()\n    };\n  }\n  \n  return {\n    ...itemData,\n    'Company Name': companyName, // Fix the typo\n    'Domain': extractedDomain,\n    'Status': 'domain_extracted',\n    'Processed Date': new Date().toISOString()\n  };\n}\n\n// Apply to all items - accessing .json property correctly\nreturn items.map(item => ({ json: extractDomain(item.json) }));"
      },
